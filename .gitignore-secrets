# git-secrets — wzorce detekcji prawdziwych sekretów
# Wzorce muszą być na tyle specyficzne żeby nie blokować README i .env.example
# Pliki z przykładami są wykluczone przez .gitallowed

# AWS — specyficzny format klucza dostępu (AKIA + 16 znaków)
AKIA[0-9A-Z]{16}

# PayU — rzeczywiste formaty wartości (nie same nazwy zmiennych)
# Merchant ID: 6-8 cyfr przypisanych przez PayU
PAYU_MERCHANT_ID=[0-9]{6,8}[^0-9]
# API Key: 32-znakowy hex (format MD5)
PAYU_API_KEY=[a-f0-9]{32}
# OAuth secret: ciąg alfanumeryczny > 20 znaków
PAYU_OAUTH_CLIENT_SECRET=[a-zA-Z0-9]{20,}

# Django secret key — rzeczywisty format (długi losowy ciąg, nie placeholder)
DJANGO_SECRET_KEY=[a-zA-Z0-9!@#$%^&*()_+\-=]{40,}

# Połączenia z bazą danych zawierające hasło w URL
postgresql://[^:]+:[^@/]{3,}@
mysql://[^:]+:[^@/]{3,}@

# Bearer tokeny (długie ciągi, nie zmienne)
[Bb]earer [a-zA-Z0-9._\-]{30,}

# Private key bloki (PEM)
-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----

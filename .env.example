# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/payment_db

# PayU Configuration (GetPayU Sandbox)
PAYU_MERCHANT_ID=your-merchant-id
PAYU_API_KEY=your-api-key
PAYU_OAUTH_CLIENT_ID=your-oauth-client-id
PAYU_OAUTH_CLIENT_SECRET=your-oauth-client-secret
PAYU_SANDBOX_MODE=true

# AWS Configuration
AWS_REGION=eu-central-1
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
AWS_SQS_PAYMENT_SUCCESS_QUEUE_URL=https://sqs.region.amazonaws.com/account-id/payment-success
AWS_SQS_PAYMENT_FAILED_QUEUE_URL=https://sqs.region.amazonaws.com/account-id/payment-failed

# Application Configuration
BASE_URL=http://localhost:8000
LOG_LEVEL=INFO

